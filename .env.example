# ================================
# Elasticsearch Configuration
# ================================
# Username pour Elasticsearch
ELASTIC_USERNAME=elastic

# Password pour Elasticsearch
ELASTIC_PASSWORD=changeme

# Port d'accès à Elasticsearch
ES_PORT=9200

# ================================
# Kibana Configuration
# ================================
# Port d'accès à Kibana UI
KIBANA_PORT=5601

# ================================
# MySQL Configuration
# ================================
# Host MySQL (localhost pour app lancée depuis IDE)
MYSQL_HOST=localhost

# Password root MySQL
MYSQL_ROOT_PASSWORD=root

# Nom de la base de données
MYSQL_DATABASE=elastic_db

# User MySQL utilisé partout (Docker + Spring Boot)
MYSQL_USER=springboot

# Password du user MySQL utilisé partout (Docker + Spring Boot)
MYSQL_PASSWORD=springboot_password

# Port d'accès à MySQL
MYSQL_PORT=3306

# ================================
# Spring Boot Configuration
# ================================
# URL Elasticsearch pour Spring Boot
SPRING_ELASTICSEARCH_REST_URIS=http://localhost:9200
